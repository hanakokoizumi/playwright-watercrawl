# Application Settings
SCRAPLING_STEALTH=false
SCRAPLING_SOLVE_CLOUDFLARE=false
SCRAPLING_LOAD_DOM=false
SCRAPLING_RETRIES=1
SCRAPLING_CONCURRENCY=3
# Deprecated: Scrapling only supports Chromium. Kept for backward compatibility.
ENGINE=chromium

# Server Settings
PORT=8000
HOST=0.0.0.0

# Environment
PYTHONUNBUFFERED=1

# Add this to .env.local to override settings for local development
AUTH_API_KEY=your-secret-api-key
DEFAULT_PROXY=
